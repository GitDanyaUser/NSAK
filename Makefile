# -----------------------------------------------------------------------------
# Directories
# -----------------------------------------------------------------------------

BUILD       := build
BOOT_DIR    := bootldr
KERNEL_DIR  := kernel
ISO_DIR     := $(BUILD)/iso_root

# -----------------------------------------------------------------------------
# Source files
# -----------------------------------------------------------------------------

BOOT_SRC    := $(BOOT_DIR)/boot.asm
STAGE2_SRC  := $(BOOT_DIR)/stage2.asm
KERNEL_SRC  := $(KERNEL_DIR)/kernel.asm

# -----------------------------------------------------------------------------
# Output files
# -----------------------------------------------------------------------------

BOOT_BIN    := $(BUILD)/boot.bin
STAGE2_BIN  := $(BUILD)/stage2.bin
KERNEL_BIN  := $(BUILD)/kernel.bin

BOOT_IMG    := $(BUILD)/os_combined.img
ISO         := $(BUILD)/nsak.iso

# -----------------------------------------------------------------------------
# Tools
# -----------------------------------------------------------------------------

NASM        := nasm
XORRISO     := xorriso

NASMFLAGS   := -f bin

# -----------------------------------------------------------------------------
# Default target
# -----------------------------------------------------------------------------

.PHONY: all clean

all: $(ISO)

# -----------------------------------------------------------------------------
# Build directories
# -----------------------------------------------------------------------------

$(BUILD):
	mkdir -p $(BUILD)

$(ISO_DIR):
	mkdir -p $(ISO_DIR)

# -----------------------------------------------------------------------------
# Assembly
# -----------------------------------------------------------------------------

$(BOOT_BIN): $(BOOT_SRC) | $(BUILD)
	$(NASM) $(NASMFLAGS) $< -o $@

$(STAGE2_BIN): $(STAGE2_SRC) | $(BUILD)
	$(NASM) $(NASMFLAGS) $< -o $@

$(KERNEL_BIN): $(KERNEL_SRC) | $(BUILD)
	$(NASM) $(NASMFLAGS) $< -o $@

# -----------------------------------------------------------------------------
# Boot image
# -----------------------------------------------------------------------------

$(BOOT_IMG): $(BOOT_BIN) $(STAGE2_BIN)
	cat $^ > $@

# -----------------------------------------------------------------------------
# ISO
# -----------------------------------------------------------------------------

$(ISO): $(BOOT_IMG) $(KERNEL_BIN) | $(ISO_DIR)
	cp $(BOOT_IMG) $(ISO_DIR)/os_combined.img
	cp $(KERNEL_BIN) $(ISO_DIR)/NSAKKRNL.BIN

	$(XORRISO) -as mkisofs \
		-iso-level 3 \
		-b os_combined.img \
		-no-emul-boot \
		-boot-load-size 32 \
		-boot-info-table \
		-o $@ \
		$(ISO_DIR)

# -----------------------------------------------------------------------------
# Cleanup
# -----------------------------------------------------------------------------

clean:
	rm -rf $(BUILD)